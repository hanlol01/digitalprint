generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PricingUnit {
  per_lembar
  per_meter
  per_cm
  per_pcs

  @@map("satuan_harga_enum")
}

enum OrderStatus {
  menunggu_desain
  proses_cetak
  finishing
  selesai
  sudah_diambil

  @@map("status_pesanan_enum")
}

enum PaymentMethod {
  cash
  transfer
  qris
  piutang

  @@map("metode_pembayaran_enum")
}

enum TransactionItemType {
  produk
  jasa
  display

  @@map("jenis_item_transaksi_enum")
}

enum UserRole {
  owner
  admin
  kasir
  operator

  @@map("peran_pengguna_enum")
}

enum StockMovementType {
  restock
  adjustment
  order_checkout

  @@map("jenis_pergerakan_stok_enum")
}

enum StockDirection {
  in
  out

  @@map("arah_pergerakan_stok_enum")
}

model User {
  id                 String   @id @default(uuid())
  username           String   @unique @map("nama_pengguna")
  passwordHash       String   @map("kata_sandi_hash")
  role               UserRole @default(admin) @map("peran")
  isActive           Boolean  @default(true) @map("aktif")
  mustChangePassword Boolean  @default(true) @map("wajib_ganti_kata_sandi")
  createdAt          DateTime @default(now()) @map("dibuat_pada")
  updatedAt          DateTime @updatedAt @map("diperbarui_pada")
  deletedAt          DateTime? @map("dihapus_pada")

  stockMovements StockMovement[]

  @@index([deletedAt])
  @@map("pengguna")
}

model ProductCategory {
  id        String    @id @default(uuid())
  code      String?   @unique @map("kode_kategori")
  name      String    @unique @map("nama")
  icon      String    @map("ikon")
  isActive  Boolean   @default(true) @map("aktif")
  createdAt DateTime  @default(now()) @map("dibuat_pada")
  updatedAt DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt DateTime? @map("dihapus_pada")

  products Product[]
  services ServiceCatalog[]
  displays DisplayCatalog[]

  @@index([deletedAt])
  @@map("kategori_produk")
}

model UnitMaster {
  id        String    @id @default(uuid())
  code      String    @unique @map("kode_satuan")
  name      String    @map("nama_satuan")
  isActive  Boolean   @default(true) @map("aktif")
  createdAt DateTime  @default(now()) @map("dibuat_pada")
  updatedAt DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt DateTime? @map("dihapus_pada")

  products Product[]
  variants ProductMaterialVariant[]
  services ServiceCatalog[]
  displays DisplayCatalog[]

  @@index([deletedAt])
  @@index([name])
  @@map("master_satuan")
}

model FinishingMaster {
  id        String    @id @default(uuid())
  code      String    @unique @map("kode_finishing")
  name      String    @map("nama_finishing")
  isActive  Boolean   @default(true) @map("aktif")
  createdAt DateTime  @default(now()) @map("dibuat_pada")
  updatedAt DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt DateTime? @map("dihapus_pada")

  variants ProductMaterialVariant[]
  services ServiceCatalog[]
  displays DisplayCatalog[]

  @@index([deletedAt])
  @@index([name])
  @@map("master_finishing")
}

model ServiceMaterialMaster {
  id        String    @id @default(uuid())
  code      String    @unique @map("kode_material")
  name      String    @map("nama_material")
  isActive  Boolean   @default(true) @map("aktif")
  createdAt DateTime  @default(now()) @map("dibuat_pada")
  updatedAt DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt DateTime? @map("dihapus_pada")

  services ServiceCatalog[]

  @@index([deletedAt])
  @@index([name])
  @@map("master_material_jasa")
}

model FrameMaster {
  id        String    @id @default(uuid())
  code      String    @unique @map("kode_rangka")
  name      String    @map("nama_rangka")
  minStock  Decimal?  @db.Decimal(14, 4) @map("stok_minimum")
  buyPrice  Int?      @map("harga_beli")
  stock     Decimal?  @db.Decimal(14, 4) @map("stok")
  isActive  Boolean   @default(true) @map("aktif")
  createdAt DateTime  @default(now()) @map("dibuat_pada")
  updatedAt DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt DateTime? @map("dihapus_pada")

  displays DisplayCatalog[]

  @@index([deletedAt])
  @@index([name])
  @@map("master_rangka")
}

model Product {
  id               String      @id @default(uuid())
  code             String?     @unique @map("kode_produk")
  legacyNumber     Int?        @unique @map("nomor_legacy")
  name             String      @map("nama")
  categoryId       String      @map("kategori_produk_id")
  unitId           String?     @map("satuan_id")
  pricingUnit      PricingUnit @map("satuan_harga")
  hasCustomSize    Boolean     @default(false) @map("punya_ukuran_kustom")
  customWidth      Decimal?    @db.Decimal(14, 4) @map("panjang_kustom")
  customHeight     Decimal?    @db.Decimal(14, 4) @map("lebar_kustom")
  finishingCost    Int         @default(0) @map("biaya_finishing")
  estimatedMinutes Int         @default(0) @map("estimasi_menit")
  isActive         Boolean     @default(true) @map("aktif")
  createdAt        DateTime    @default(now()) @map("dibuat_pada")
  updatedAt        DateTime    @updatedAt @map("diperbarui_pada")
  deletedAt        DateTime?   @map("dihapus_pada")

  category ProductCategory @relation(fields: [categoryId], references: [id])
  unit     UnitMaster?     @relation(fields: [unitId], references: [id])
  variants ProductMaterialVariant[]
  orderItems OrderItem[]
  services ServiceCatalog[]
  displays DisplayCatalog[]

  @@index([categoryId])
  @@index([unitId])
  @@index([deletedAt])
  @@index([name])
  @@map("produk")
}

model ProductMaterialVariant {
  id           String    @id @default(uuid())
  code         String?   @unique @map("kode_varian")
  productId    String    @map("produk_id")
  materialId   String    @map("bahan_id")
  unitId       String?   @map("satuan_id")
  finishingId  String?   @map("finishing_id")
  name         String    @map("nama")
  costPrice    Int       @map("harga_modal")
  sellingPrice Int       @map("harga_jual")
  minimumOrder Int       @default(1) @map("minimum_order")
  estimateText String?   @map("estimasi_teks")
  isActive     Boolean   @default(true) @map("aktif")
  createdAt    DateTime  @default(now()) @map("dibuat_pada")
  updatedAt    DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt    DateTime? @map("dihapus_pada")

  product   Product          @relation(fields: [productId], references: [id])
  material  Material         @relation("BahanVarianProduk", fields: [materialId], references: [id])
  unit      UnitMaster?      @relation(fields: [unitId], references: [id])
  finishing FinishingMaster? @relation(fields: [finishingId], references: [id])
  recipes   VariantMaterialRecipe[]
  orderItems OrderItem[]

  @@index([productId])
  @@index([materialId])
  @@index([unitId])
  @@index([finishingId])
  @@index([deletedAt])
  @@map("varian_bahan_produk")
}

model Material {
  id            String    @id @default(uuid())
  code          String?   @unique @map("kode_bahan")
  name          String    @unique @map("nama")
  unit          String    @map("satuan")
  costPrice     Int       @default(0) @map("harga_modal")
  sellingPrice  Int       @default(0) @map("harga_jual")
  currentStock  Decimal   @db.Decimal(14, 4) @map("stok_saat_ini")
  minStock      Decimal   @db.Decimal(14, 4) @map("stok_minimum")
  lastRestocked DateTime  @map("terakhir_restok")
  isActive      Boolean   @default(true) @map("aktif")
  createdAt     DateTime  @default(now()) @map("dibuat_pada")
  updatedAt     DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt     DateTime? @map("dihapus_pada")

  recipes       VariantMaterialRecipe[]
  productVariants ProductMaterialVariant[] @relation("BahanVarianProduk")
  displays DisplayCatalog[]
  stockMovements StockMovement[]

  @@index([deletedAt])
  @@index([name])
  @@map("bahan")
}

model ServiceCatalog {
  id                String    @id @default(uuid())
  code              String    @unique @map("kode_jasa")
  productId         String    @map("produk_id")
  categoryId        String    @map("kategori_produk_id")
  unitId            String    @map("satuan_id")
  serviceMaterialId String    @map("material_jasa_id")
  finishingId       String    @map("finishing_id")
  sellingPrice      Int       @map("harga_jual")
  estimateText      String?   @map("estimasi_teks")
  isActive          Boolean   @default(true) @map("aktif")
  createdAt         DateTime  @default(now()) @map("dibuat_pada")
  updatedAt         DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt         DateTime? @map("dihapus_pada")

  product         Product               @relation(fields: [productId], references: [id])
  category        ProductCategory       @relation(fields: [categoryId], references: [id])
  unit            UnitMaster            @relation(fields: [unitId], references: [id])
  serviceMaterial ServiceMaterialMaster @relation(fields: [serviceMaterialId], references: [id])
  finishing       FinishingMaster       @relation(fields: [finishingId], references: [id])
  orderItems      OrderItem[]

  @@index([productId])
  @@index([categoryId])
  @@index([unitId])
  @@index([serviceMaterialId])
  @@index([finishingId])
  @@index([deletedAt])
  @@map("katalog_jasa")
}

model DisplayCatalog {
  id           String    @id @default(uuid())
  code         String    @unique @map("kode_display")
  name         String    @map("nama_display")
  productId    String    @map("produk_id")
  categoryId   String    @map("kategori_produk_id")
  unitId       String    @map("satuan_id")
  frameId      String    @map("rangka_id")
  materialId   String    @map("bahan_id")
  finishingId  String    @map("finishing_id")
  sellingPrice Int       @map("harga_jual")
  minimumOrder Int       @default(1) @map("minimum_order")
  estimateText String?   @map("estimasi_teks")
  isActive     Boolean   @default(true) @map("aktif")
  createdAt    DateTime  @default(now()) @map("dibuat_pada")
  updatedAt    DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt    DateTime? @map("dihapus_pada")

  product    Product         @relation(fields: [productId], references: [id])
  category   ProductCategory @relation(fields: [categoryId], references: [id])
  unit       UnitMaster      @relation(fields: [unitId], references: [id])
  frame      FrameMaster     @relation(fields: [frameId], references: [id])
  material   Material        @relation(fields: [materialId], references: [id])
  finishing  FinishingMaster @relation(fields: [finishingId], references: [id])
  orderItems OrderItem[]

  @@index([productId])
  @@index([categoryId])
  @@index([unitId])
  @@index([frameId])
  @@index([materialId])
  @@index([finishingId])
  @@index([deletedAt])
  @@map("katalog_display")
}

model VariantMaterialRecipe {
  id           String   @id @default(uuid())
  variantId    String   @map("varian_bahan_produk_id")
  materialId   String   @map("bahan_id")
  usagePerUnit Decimal  @db.Decimal(14, 6) @map("pemakaian_per_satuan")
  createdAt    DateTime @default(now()) @map("dibuat_pada")
  updatedAt    DateTime @updatedAt @map("diperbarui_pada")

  variant  ProductMaterialVariant @relation(fields: [variantId], references: [id])
  material Material               @relation(fields: [materialId], references: [id])

  @@unique([variantId, materialId])
  @@index([materialId])
  @@map("resep_bahan_varian")
}

model Customer {
  id            String    @id @default(uuid())
  name          String    @map("nama")
  phone         String    @unique @map("no_telepon")
  email         String?   @map("email")
  totalSpent    Int       @default(0) @map("total_belanja")
  totalOrders   Int       @default(0) @map("total_pesanan")
  loyaltyPoints Int       @default(0) @map("poin_loyalitas")
  isActive      Boolean   @default(true) @map("aktif")
  createdAt     DateTime  @default(now()) @map("dibuat_pada")
  updatedAt     DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt     DateTime? @map("dihapus_pada")

  orders Order[]

  @@index([deletedAt])
  @@index([name])
  @@map("pelanggan")
}

model Order {
  id               String        @id @default(uuid())
  orderNumber      String        @unique @map("nomor_pesanan")
  customerId       String?       @map("pelanggan_id")
  customerName     String        @map("nama_pelanggan")
  customerPhone    String        @map("telepon_pelanggan")
  paymentMethod    PaymentMethod @map("metode_pembayaran")
  status          OrderStatus   @default(menunggu_desain)
  subtotal        Int
  discount        Int           @default(0) @map("diskon")
  tax             Int           @default(0) @map("pajak")
  total           Int
  notes           String        @default("") @map("catatan")
  deadline        DateTime?     @map("tenggat_waktu")
  designFileUrl   String?       @map("url_file_desain")
  estimatedMinutes Int          @default(0) @map("estimasi_menit")
  createdAt       DateTime      @default(now()) @map("dibuat_pada")
  updatedAt       DateTime      @updatedAt @map("diperbarui_pada")
  deletedAt       DateTime?     @map("dihapus_pada")

  customer Customer? @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  stockMovements StockMovement[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("pesanan")
}

model OrderItem {
  id               String      @id @default(uuid())
  orderId          String      @map("pesanan_id")
  productId        String      @map("produk_id")
  variantId        String?     @map("varian_bahan_produk_id")
  serviceId        String?     @map("katalog_jasa_id")
  displayId        String?     @map("katalog_display_id")
  itemType         TransactionItemType @default(produk) @map("jenis_item")
  itemLabel        String?     @map("label_item")
  unitLabel        String?     @map("label_satuan")
  referenceCode    String?     @map("kode_referensi")
  productName      String      @map("nama_produk")
  variantName      String      @map("nama_varian")
  pricingUnit      PricingUnit @map("satuan_harga")
  unitPrice        Int         @map("harga_satuan")
  quantity         Int         @default(1) @map("jumlah")
  width            Decimal?    @db.Decimal(14, 4) @map("panjang")
  height           Decimal?    @db.Decimal(14, 4) @map("lebar")
  notes            String      @default("") @map("catatan")
  finishing       Boolean     @default(false)
  finishingCost   Int         @default(0) @map("biaya_finishing")
  subtotal        Int
  estimatedMinutes Int        @default(0) @map("estimasi_menit")
  createdAt       DateTime    @default(now()) @map("dibuat_pada")

  order   Order                  @relation(fields: [orderId], references: [id])
  product Product                @relation(fields: [productId], references: [id])
  variant ProductMaterialVariant? @relation(fields: [variantId], references: [id])
  service ServiceCatalog?        @relation(fields: [serviceId], references: [id])
  display DisplayCatalog?        @relation(fields: [displayId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@index([serviceId])
  @@index([displayId])
  @@index([itemType])
  @@map("item_pesanan")
}

model StockMovement {
  id           String            @id @default(uuid())
  materialId   String            @map("bahan_id")
  orderId      String?           @map("pesanan_id")
  userId       String?           @map("pengguna_id")
  type         StockMovementType @map("jenis")
  direction    StockDirection    @map("arah")
  quantity     Decimal           @db.Decimal(14, 4) @map("jumlah")
  balanceAfter Decimal           @db.Decimal(14, 4) @map("saldo_setelah")
  notes        String            @default("") @map("catatan")
  createdAt    DateTime          @default(now()) @map("dibuat_pada")

  material Material @relation(fields: [materialId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([materialId])
  @@index([orderId])
  @@index([createdAt])
  @@map("pergerakan_stok")
}

model Expense {
  id          String    @id @default(uuid())
  date        DateTime  @map("tanggal")
  category    String    @map("kategori")
  description String    @map("keterangan")
  amount      Int       @map("jumlah")
  createdAt   DateTime  @default(now()) @map("dibuat_pada")
  updatedAt   DateTime  @updatedAt @map("diperbarui_pada")
  deletedAt   DateTime? @map("dihapus_pada")

  @@index([date])
  @@index([category])
  @@index([deletedAt])
  @@map("pengeluaran")
}
